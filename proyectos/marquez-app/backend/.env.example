# ── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de datos PostgreSQL (Supabase) ─────────────────────
# Obtén esto en: supabase.com → tu proyecto → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── Anthropic API ────────────────────────────────────────────
# Obtén esto en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── JWT (genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio

# ── Frontend (CORS) ──────────────────────────────────────────
# En desarrollo:
FRONTEND_URL=http://localhost:5173
# En producción:
# FRONTEND_URL=https://marquez.vercel.app
